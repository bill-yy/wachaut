# Wachaut SFU — Environment Variables
PORT=3002
HOST=0.0.0.0

# WebRTC media ports
RTC_MIN_PORT=10000
RTC_MAX_PORT=10100
RTC_LISTEN_IP=0.0.0.0

# Public IP for WebRTC (REQUIRED for production)
# Set this to your server's public IP
RTC_ANNOUNCED_IP=

# Number of mediasoup workers (1 per CPU core)
NUM_WORKERS=4
