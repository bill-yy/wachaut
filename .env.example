# Wachaut — Environment variables for production deployment.
# Copy to .env and fill in real values. NEVER commit the real .env.

# TURN server shared secret (must match between coturn and the SFU).
# Generate with: openssl rand -hex 32
TURN_SECRET=changeme

# TURN URL that clients use to connect (used by the SFU to mint credentials).
TURN_URL=turn:wachaut.billytech.es:3478?transport=udp

# SFU public IP for ICE candidates (the server's external IP).
RTC_ANNOUNCED_IP=

# Allowed CORS origins (comma-separated).
ALLOWED_ORIGINS=https://wachaut.billytech.es
